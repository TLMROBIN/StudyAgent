APP_NAME=StudyAgent API
APP_ENV=development
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

JWT_SECRET_KEY=change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=StudyAgent123

DATABASE_URL=sqlite:///data/studyagent.db
SQLITE_PATH=data/studyagent.db
CHROMADB_PATH=data/chromadb
CHROMADB_MODE=persistent
CHROMADB_HOST=127.0.0.1
CHROMADB_PORT=8000
CHROMADB_SSL=false
GRAFANA_PORT=3001
CHROMADB_COLLECTION_PREFIX=studyagent
UPLOAD_PATH=data/uploads
TASK_ARTIFACT_PATH=data/tasks

REDIS_URL=redis://127.0.0.1:6379/0
CELERY_BROKER_URL=redis://127.0.0.1:6379/1
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/2
REDIS_KEY_PREFIX=studyagent
REDIS_CONNECT_TIMEOUT_SECONDS=1

LLM_PRIMARY_NAME=minimax
LLM_PRIMARY_BASE_URL=https://api.minimaxi.com/v1
LLM_PRIMARY_API_KEY=
LLM_PRIMARY_MODEL=MiniMax-M2.7-highspeed

LLM_FALLBACK_NAME=qwen
LLM_FALLBACK_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_FALLBACK_API_KEY=
LLM_FALLBACK_MODEL=qwen-plus

LLM_MAX_QPS=10
LLM_REQUEST_TIMEOUT_SECONDS=30
LLM_CIRCUIT_BREAKER_THRESHOLD=3
LLM_CIRCUIT_BREAKER_SECONDS=60
HOT_QUESTION_CACHE_TTL_SECONDS=1800
CHAT_REQUEST_REPLAY_TTL_SECONDS=900

QUEUE_MAX_WAITING=200
QUEUE_MAX_CONCURRENT=20
INGEST_SOFT_TIME_LIMIT_SECONDS=540
INGEST_HARD_TIME_LIMIT_SECONDS=600
PDF_PARSER_BACKEND=legacy
MINERU_PYTHON_BIN=/home/binyu/文档/trae_projects/.runtime/mineru-venv/bin/python
MINERU_BACKEND=pipeline
MINERU_PARSE_METHOD=auto
MINERU_LANG=ch
MINERU_DEVICE=cuda
MINERU_DEVICE_MODE=cuda
MINERU_MODEL_SOURCE=local
MINERU_REQUIRE_GPU_PROOF=true
MINERU_PARSE_TIMEOUT_SECONDS=480
MINERU_PARSE_WARN_SECONDS=240

UPLOAD_MAX_BYTES=52428800
ALLOWED_UPLOAD_EXTENSIONS=.pdf,.docx,.txt
ALLOWED_UPLOAD_MIME_TYPES=application/pdf,application/vnd.openxmlformats-officedocument.wordprocessingml.document,text/plain

EMBEDDING_MODEL_NAME=BAAI/bge-m3
EMBEDDING_DIMENSION=1024
EMBEDDING_DEVICE=auto
EMBEDDING_BATCH_SIZE=16
EMBEDDING_BACKEND=sentence-transformers
EMBEDDING_FALLBACK_TO_HASH=true
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=64
RAG_TOP_K=4
